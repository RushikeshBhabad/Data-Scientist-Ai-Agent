# Groq API Key (required) — Get from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# GitHub Token (optional) — For dataset search. Get from https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# HuggingFace API Token (optional) — For HuggingFace models. Get from https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here
